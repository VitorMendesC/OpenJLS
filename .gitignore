# Directories
backups/
project_testbenches/
sim/
Papers/
Verification/T87 conformance/Reference Images
Verification/T87 conformance/Output
build/

# OSVVM (source-built; see Verification/OSVVM)
Verification/OSVVM/nvc-libs/
# fast-flow scratch (per-run OSVVM YAML)
Verification/OSVVM/sim-out/
# script-flow outputs (build_reports.sh: libraries, per-build report trees)
Verification/OSVVM/VHDL_LIBS/
Verification/OSVVM/osvvm/
Verification/OSVVM/OSVVM_OpenJls/
Verification/OSVVM/OsvvmTemp_NVC/
# code-coverage flow outputs (build_coverage.sh: per-test covdb + HTML)
Verification/OSVVM/NVC_CodeCoverage/
Verification/OSVVM/*.html
Verification/OSVVM/*.yml
# Verification-only third-party deps are not committed; fetch_third_party.sh
# (re)materializes them from their pinned upstreams, license texts included.
# (open-logic stays committed — the core RTL instantiates its primitives, so the
# IP must build without running the fetch script.)
ThirdParty/osvvm/
ThirdParty/osvvm-scripts/
ThirdParty/tcllib/
ThirdParty/charls/

# NVC compile cache
Verification/T87 conformance/work-lib/

# Post-synth flow (netlist + libraries + scratch are all regenerated)
Verification/Post synth/Output/
Verification/Post synth/work-lib/
Verification/Post synth/work-lib-golden/
Verification/Post synth/sim-out/
Verification/Post synth/scratch/

# Golden model (minted goldens + OpenJLS results; CharLS lives under ThirdParty)
Verification/Golden model/Output/
Verification/Golden model/work-lib/
# Fetched/normalized test images (regenerated by prepare_images.sh) + scratch
Verification/Golden model/Images/
Verification/Golden model/.imgsrc/

# Python
__pycache__/

# Files
settings.json

# Extensions
*.log
*.jou
*.pb
*.o
*.exe

# IP packaging scratch projects (package_ip.tcl work_root, wiped each run)
ip_pkg/
